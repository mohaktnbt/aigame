# ===========================================
# Project Nexus — Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# LLM
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Database (TimescaleDB)
DATABASE_URL=postgresql://nexus:nexus@localhost:5432/nexus

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=nexus

# Redis
REDIS_URL=redis://localhost:6379

# Agent Memory (Zep Cloud)
ZEP_API_KEY=

# Auth (Clerk)
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Payments (Stripe)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Storage (MinIO)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=nexus
MINIO_SECRET_KEY=nexus123

# Service URLs (for inter-service communication)
GAME_ENGINE_URL=http://localhost:5001
SWARM_ENGINE_URL=http://localhost:5002
API_GATEWAY_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
